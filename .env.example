# ─────────────────────────────────────────────
# Firebase — copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# En Cloudflare Pages agrega estas variables en:
#   Settings → Environment variables
# ─────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_ID=your_firestore_database_id
VITE_FIREBASE_MEASUREMENT_ID=

# ─────────────────────────────────────────────
# Gemini API Key — sólo se usa en el servidor (Cloudflare Worker)
# NO la pongas con prefijo VITE_ o quedará expuesta en el bundle del cliente
# Configura GEMINI_API_KEY SÓLO en Cloudflare Pages → Settings → Environment variables
# ─────────────────────────────────────────────
